generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
PROJECT_ADMIN
QA_LEAD
TESTER
VIEWER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RequirementPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TestCasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExecutionStatus {
  NOT_STARTED
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

enum ExecutionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DefectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DefectSeverity {
  MINOR
  MAJOR
  CRITICAL
  BLOCKER
}

enum DefectStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}

model Organization {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  projects Project[]
}

model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  phoneNumber String?
  password  String
  role       UserRole

  isActive   Boolean  @default(true)
  lastLogin DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(uuid())
  name        String
  projectKey  String        @unique
  description String?
  status      ProjectStatus @default(ACTIVE)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  requirements Requirement[]
}

model Requirement {
  id            String  @id @default(uuid())
  requirementId String  @unique
  title         String
  description   String?

  priority RequirementPriority @default(MEDIUM)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  testCases TestCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestCase {
  id          String  @id @default(uuid())
  testCaseId  String  @unique
  title       String
  description String?

  priority TestCasePriority @default(MEDIUM)

  requirementId String
  requirement   Requirement @relation(fields: [requirementId], references: [id])

  executions TestExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestExecution {
  id String @id @default(uuid())

  executionId String @unique
  title       String

  status   ExecutionStatus   @default(NOT_STARTED)
  priority ExecutionPriority @default(MEDIUM)

  comments String?

  testCaseId String
  testCase   TestCase @relation(fields: [testCaseId], references: [id])

  defects Defect[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Defect {
  id String @id @default(uuid())

  defectId    String  @unique
  title       String
  description String?

  priority DefectPriority @default(MEDIUM)
  severity DefectSeverity @default(MAJOR)
  status   DefectStatus   @default(OPEN)

  environment String?

  executionId String
  execution   TestExecution @relation(fields: [executionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
